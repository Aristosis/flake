layout {
  border {
    active-color   "#d1bcfd"
    inactive-color "#948f99"
    urgent-color   "#ffb4ab"
  }

  shadow {
    color "#00000070"
  }

  tab-indicator {
    active-color   "#d1bcfd"
    inactive-color "#948f99"
    urgent-color   "#ffb4ab"
  }

  insert-hint {
    color "#d1bcfd80"
  }
}

